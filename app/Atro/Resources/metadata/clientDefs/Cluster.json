{
  "iconClass": "copy",
  "controller": "controllers/record",
  "createDisabled": true,
  "views": {
    "detail": "views/cluster/detail"
  },
  "recordViews": {
    "detail": "views/cluster/record/detail"
  },
  "relationshipPanels": {
    "clusterItems": {
      "actions": {
        "quickView": {
          "disabled": true
        },
        "quickEdit": {
          "disabled": true
        },
        "confirm": {
          "url": "ClusterItem/confirm",
          "confirm": false,
          "refresh": true,
          "iconClass": "ph ph-check",
          "sortOrder": 10
        },
        "reject": {
          "url": "ClusterItem/reject",
          "confirm": false,
          "refresh": true,
          "iconClass": "ph ph-x",
          "sortOrder": 20
        },
        "unmerge": {
          "url": "ClusterItem/unmerge",
          "confirm": false,
          "refresh": true,
          "iconClass": "ph ph-arrows-split",
          "sortOrder": 30
        },
        "move": {
          "url": "ClusterItem/move",
          "refresh": true,
          "iconClass": "ph ph-arrow-right",
          "sortOrder": 40,
          "modalSelectEntity": "Cluster",
          "modalSelectWhere": [
            {"type": "equals", "attribute": "masterEntity", "value": "{{masterEntity}}"}
          ]
        },
        "removeRelated": {
          "url": "{{entityName}}/{{entityId}}",
          "refresh": true
        }
      },
      "hideShowFullList": true,
      "create": false,
      "select": false,
      "unlink": false,
      "canClose": false,
      "sortBy": "createdAt",
      "asc": false
    },
    "rejectedClusterItems": {
      "actions": {
        "quickView": {
          "disabled": true
        },
        "quickEdit": {
          "disabled": true
        },
        "removeRelated": {
          "disabled": true
        },
        "unreject": {
          "url": "ClusterItem/unreject",
          "confirm": false,
          "refresh": true,
          "iconClass": "ph ph-arrow-u-up-left",
          "sortOrder": 20
        }
      },
      "checkboxes": false,
      "create": false,
      "hideShowFullList": true,
      "select": false,
      "unlink": false,
      "sortBy": "createdAt",
      "asc": false
    }
  }
}