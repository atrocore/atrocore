{
  "fields": {
    "name": {
      "type": "varchar",
      "view": "views/fields/entity-type",
      "required": true,
      "unique": true,
      "customizable": false,
      "layoutRemoveDisabled": true,
      "conditionalProperties": {
        "protected": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "id"
            }
          ]
        }
      }
    },
    "updateMasterAutomatically": {
      "type": "bool",
      "default": false
    },
    "executeMergeAs": {
      "type": "enum",
      "default": "system",
      "options": [
        "system",
        "sameUser"
      ],
      "tooltip": true
    },
    "mergingScript": {
      "type": "text",
      "view": "views/fields/script",
      "language": "json",
      "default": "{# { \"skipped\": false, \"masterRecordData\": { \"name\" : \"{{ contributorRecord.name }}\" } } #}",
      "editorActions": {
        "addFields": {
          "entityNameField": "entityName"
        },
        "addAttributes": {
          "entityNameField": "entityName"
        }
      },
      "twigVariables": [
        "contributorRecord",
        "contributorRecords",
        "masterRecord"
      ],
      "customizable": false,
      "layoutRemoveDisabled": true,
      "tooltip": true
    },
    "confirmAutomatically": {
      "type": "bool"
    },
    "deleteInvalidMastersAutomatically": {
      "type": "bool"
    },
    "minimumMatchingScore": {
      "type": "int",
      "default": 100,
      "min": 1,
      "max": 100,
      "conditionalProperties": {
        "visible": {
          "conditionGroup": [
            {
              "type": "isTrue",
              "attribute": "confirmAutomatically"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "isTrue",
              "attribute": "confirmAutomatically"
            }
          ]
        }
      }
    },
    "description": {
      "type": "text"
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "modifiedBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    }
  },
  "links": {
    "sourceToStagingPipelines": {
      "type": "hasMany",
      "entity": "SourceToStagingPipeline",
      "foreign": "stagingEntity"
    },
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    }
  },
  "indexes": {
    "createdAt": {
      "columns": [
        "createdAt",
        "deleted"
      ]
    },
    "modifiedAt": {
      "columns": [
        "modifiedAt",
        "deleted"
      ]
    }
  }
}