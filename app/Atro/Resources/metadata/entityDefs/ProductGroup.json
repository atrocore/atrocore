{
  "fields": {
    "name": {
      "type": "varchar",
      "required": true,
      "trim": true
    },
    "description": {
      "type": "text"
    },
    "code": {
      "type": "varchar",
      "trim": true,
      "defaultValueType": "basic",
      "unique": true,
      "index": true
    },
    "itemType": {
      "type": "enum",
      "options": [
        "physical_goods",
        "services",
        "digital_products",
        "legal_rights"
      ]
    },
    "products": {
      "type": "linkMultiple",
      "foreignName": "name",
      "noLoad": true,
      "layoutDetailDisabled": true,
      "massUpdateDisabled": true
    },
    "children": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutNavigationDisabled": true,
      "noLoad": true
    },
    "parents": {
      "type": "linkMultiple",
      "view": "views/fields/hierarchy-parents",
      "layoutNavigationDisabled": true,
      "noLoad": true
    },
    "sortOrder": {
      "type": "int",
      "default": null
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "modifiedBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    }
  },
  "links": {
    "products": {
      "type": "hasMany",
      "foreign": "productGroup",
      "entity": "Product"
    },
    "children": {
      "type": "hasMany",
      "relationName": "ProductGroupHierarchy",
      "foreign": "parents",
      "entity": "ProductGroup",
      "midKeys": [
        "entityId",
        "parentId"
      ]
    },
    "parents": {
      "type": "hasMany",
      "relationName": "ProductGroupHierarchy",
      "foreign": "children",
      "entity": "ProductGroup",
      "midKeys": [
        "parentId",
        "entityId"
      ]
    },
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    }
  },
  "indexes": {
    "name": {
      "columns": [
        "name",
        "deleted"
      ]
    },
    "createdAt": {
      "columns": [
        "createdAt",
        "deleted"
      ]
    },
    "modifiedAt": {
      "columns": [
        "modifiedAt",
        "deleted"
      ]
    }
  },
  "collection": {
    "asc": false
  }
}
